# Bakong API
BAKONG_BASE_URL=http://10.169.111.11
BAKONG_USERNAME=your_username
BAKONG_PASSWORD=your_password

# Alert when balance goes below these values
THRESHOLD_USD=10000.0
THRESHOLD_KHR=1000000.0

# Telegram: one bot token; two chat IDs (can be same or different)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
# Chat that receives balance summary on every run (every 5 min)
TELEGRAM_CHAT_ID_NOTIFICATION=your_notification_chat_id

# Cron: every 5 minutes
BALANCE_CHECK_CRON=*/5 * * * *
